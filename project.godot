; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="sec-2026-software"
run/main_scene="res://Assets/Scenes/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://Assets/Characters/icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"
DialogueController="*uid://bawb1w8s040b5"
Global="*uid://owhk806xxj6f"
Map="*uid://bibagfu4vyltt"

[dialogic]

directories/dch_directory={
